{
  "name": "hpu-guider-agent",
  "version": "1.5.0",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "electron": "electron .",
    "build:win": "electron-builder --win",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.hpu.guider",
    "productName": "hpuGuiderAgent",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.js"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "dist/assets/hpu_guider_agent_icon-BKCqxgYB.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
